import asyncio
from playwright.async_api import async_playwright
import time
import random

# Configuration
BASE_URL = "{{ base_url }}"
OUTPUT_FORMAT = "{{ output_format }}"
HEADLESS = True

{% if proxy %}
PROXY = {
    "server": "{{ proxy.server }}",
    {% if proxy.username %}
    "username": "{{ proxy.username }}",
    "password": "{{ proxy.password }}"
    {% endif %}
}
{% endif %}

{% if login %}
async def login(page):
    """Handle authentication"""
    await page.goto("{{ login.url }}")
    await page.fill("{{ login.username_selector }}", "")  # TODO: Fill credentials
    await page.fill("{{ login.password_selector }}", "")
    await page.click("{{ login.submit_selector | default('button[type=submit]') }}")
    await page.wait_for_load_state("networkidle")
{% endif %}

async def scrape_page(page):
    """Scrape data from current page"""
    await page.wait_for_load_state("networkidle")

    results = []
    {% for selector in selectors %}
    # Extract: {{ selector.description }}
    elements = await page.query_selector_all("{{ selector.css }}")
    for el in elements:
        text = await el.inner_text()
        results.append({
            "{{ selector.name }}": text.strip()
        })
    {% endfor %}

    return results

{% if pagination and pagination.type == "next_button" %}
async def scrape_all(page):
    """Scrape with next-button pagination"""
    all_results = []
    page_num = 1

    await page.goto(BASE_URL)
    {% if login %}
    await login(page)
    await page.goto(BASE_URL)
    {% endif %}

    while True:
        print(f"Scraping page {page_num}...")
        results = await scrape_page(page)
        all_results.extend(results)

        next_btn = await page.query_selector("{{ pagination.selector }}")
        if not next_btn:
            break

        await next_btn.click()
        await page.wait_for_load_state("networkidle")
        page_num += 1
        await asyncio.sleep(random.uniform(1, 3))

    return all_results
{% elif pagination and pagination.type == "infinite_scroll" %}
async def scrape_all(page):
    """Scrape with infinite scroll"""
    await page.goto(BASE_URL)
    {% if login %}
    await login(page)
    await page.goto(BASE_URL)
    {% endif %}

    prev_height = 0
    while True:
        curr_height = await page.evaluate("document.body.scrollHeight")
        if curr_height == prev_height:
            break
        await page.evaluate("window.scrollTo(0, document.body.scrollHeight)")
        await asyncio.sleep(2)
        prev_height = curr_height

    return await scrape_page(page)
{% else %}
async def scrape_all(page):
    """Scrape the target page"""
    await page.goto(BASE_URL)
    {% if login %}
    await login(page)
    await page.goto(BASE_URL)
    {% endif %}
    return await scrape_page(page)
{% endif %}

def save_results(results):
    """Save scraped data"""
    {% if output_format == "json" or output_format == "both" %}
    import json
    with open("{{ name }}_data.json", "w") as f:
        json.dump(results, f, indent=2)
    print(f"Saved {len(results)} results to {{ name }}_data.json")
    {% endif %}
    {% if output_format == "csv" or output_format == "both" %}
    import csv
    if results:
        with open("{{ name }}_data.csv", "w", newline="") as f:
            writer = csv.DictWriter(f, fieldnames=results[0].keys())
            writer.writeheader()
            writer.writerows(results)
        print(f"Saved {len(results)} results to {{ name }}_data.csv")
    {% endif %}

async def main():
    async with async_playwright() as p:
        browser = await p.chromium.launch(
            headless=HEADLESS,
            {% if proxy %}
            proxy=PROXY
            {% endif %}
        )
        context = await browser.new_context(
            user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
        )
        page = await context.new_page()

        results = await scrape_all(page)
        save_results(results)
        print(f"Done! Scraped {len(results)} items.")

        await browser.close()

if __name__ == "__main__":
    asyncio.run(main())
