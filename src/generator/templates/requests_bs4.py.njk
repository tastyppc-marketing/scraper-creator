import requests
from bs4 import BeautifulSoup
import time
import random

# Configuration
BASE_URL = "{{ base_url }}"
OUTPUT_FORMAT = "{{ output_format }}"
HEADERS = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

{% if proxy %}
PROXY = {
    "http": "{{ proxy.server }}",
    "https": "{{ proxy.server }}"
}
{% endif %}

{% if login %}
def login(session):
    """Handle authentication"""
    login_url = "{{ login.url }}"
    # TODO: Fill in login credentials
    session.post(login_url, data={"username": "", "password": ""})
{% endif %}

def scrape_page(url, session=None):
    """Scrape a single page"""
    s = session or requests.Session()
    response = s.get(url, headers=HEADERS{% if proxy %}, proxies=PROXY{% endif %})
    soup = BeautifulSoup(response.text, "lxml")

    results = []
    {% for selector in selectors %}
    # Extract: {{ selector.description }}
    elements = soup.select("{{ selector.css }}")
    for el in elements:
        results.append({
            "{{ selector.name }}": el.get_text(strip=True)
        })
    {% endfor %}

    return results

{% if pagination %}
def scrape_all():
    """Scrape with pagination"""
    all_results = []
    session = requests.Session()
    {% if login %}
    login(session)
    {% endif %}

    url = BASE_URL
    page = 1
    while url:
        print(f"Scraping page {page}...")
        results = scrape_page(url, session)
        all_results.extend(results)

        # Handle pagination
        response = session.get(url, headers=HEADERS)
        soup = BeautifulSoup(response.text, "lxml")
        next_link = soup.select_one("{{ pagination.selector }}")
        url = next_link["href"] if next_link else None
        if url and not url.startswith("http"):
            url = BASE_URL.rstrip("/") + "/" + url.lstrip("/")

        page += 1
        time.sleep(random.uniform(1, 3))

    return all_results
{% else %}
def scrape_all():
    """Scrape the target page"""
    session = requests.Session()
    {% if login %}
    login(session)
    {% endif %}
    return scrape_page(BASE_URL, session)
{% endif %}

def save_results(results):
    """Save scraped data"""
    {% if output_format == "json" or output_format == "both" %}
    import json
    with open("{{ name }}_data.json", "w") as f:
        json.dump(results, f, indent=2)
    print(f"Saved {len(results)} results to {{ name }}_data.json")
    {% endif %}
    {% if output_format == "csv" or output_format == "both" %}
    import csv
    if results:
        with open("{{ name }}_data.csv", "w", newline="") as f:
            writer = csv.DictWriter(f, fieldnames=results[0].keys())
            writer.writeheader()
            writer.writerows(results)
        print(f"Saved {len(results)} results to {{ name }}_data.csv")
    {% endif %}

if __name__ == "__main__":
    results = scrape_all()
    save_results(results)
    print(f"Done! Scraped {len(results)} items.")
